        <!-- SECTION 2: INFO HUB (Direct vs. Virtual & High Impact rankings) -->
        <section id="info" class="py-20 bg-white border-y border-slate-100">
            <div class="max-w-7xl mx-auto px-6">
                
                <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
                    <h2 class="font-display font-bold text-3xl sm:text-4xl text-slate-900">What is Virtual Water?</h2>
                    <p class="text-slate-600 text-lg">
                        Unlike "direct" water that pours clearly from a faucet, virtual water represents the hidden footprint: the entire volume of water used to grow your food, generate electricity, and fabricate your clothes.
                    </p>
                </div>

                <!-- Two Column Definition Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
                    <!-- Direct Water Card -->
                    <div class="p-8 sm:p-10 rounded-3xl bg-water-50 border border-water-100 flex flex-col justify-between">
                        <div class="space-y-4">
                            <div class="w-12 h-12 rounded-2xl bg-water-600 flex items-center justify-center text-white shadow-lg shadow-water-600/10">
                                <i class="fa-solid fa-faucet-drip text-xl"></i>
                            </div>
                            <h3 class="font-display font-bold text-2xl text-slate-900">Direct Water Use</h3>
                            <p class="text-slate-600 leading-relaxed">
                                The visible fresh water that exits municipal piping inside your household. This is the water you physically control and see every single day.
                            </p>
                            <ul class="space-y-2 text-slate-600 font-medium">
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-water-600"></i>
                                    <span>Showering & Bathing</span>
                                </li>
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-water-600"></i>
                                    <span>Flushing Toilets</span>
                                </li>
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-water-600"></i>
                                    <span>Washing Dishes & Laundry</span>
                                </li>
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-water-600"></i>
                                    <span>Drinking & Cooking Tap Water</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Virtual Water Card -->
                    <div class="p-8 sm:p-10 rounded-3xl bg-teal-50/50 border border-teal-100 flex flex-col justify-between">
                        <div class="space-y-4">
                            <div class="w-12 h-12 rounded-2xl bg-earth-600 flex items-center justify-center text-white shadow-lg shadow-earth-600/10">
                                <i class="fa-solid fa-shirt text-xl"></i>
                            </div>
                            <h3 class="font-display font-bold text-2xl text-slate-900">Virtual Water Use</h3>
                            <p class="text-slate-600 leading-relaxed">
                                The total supply-chain volume required behind closed doors to create agricultural goods, process raw items, wash machinery, and generate textiles.
                            </p>
                            <ul class="space-y-2 text-slate-600 font-medium">
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-earth-600"></i>
                                    <span>Growing livestock feed (grain & hay)</span>
                                </li>
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-earth-600"></i>
                                    <span>Irrigating agricultural fiber crops (cotton)</span>
                                </li>
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-earth-600"></i>
                                    <span>Industrial chemical processing & dyeing</span>
                                </li>
                                <li class="flex items-center space-x-2">
                                    <i class="fa-solid fa-check text-earth-600"></i>
                                    <span>Cooling systems inside manufacturing sites</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Product High-Impact Rankings -->
                <div class="border border-slate-100 bg-slate-50 p-8 sm:p-12 rounded-3xl">
                    <div class="max-w-2xl mb-10">
                        <h3 class="font-display font-bold text-2xl text-slate-900 mb-2">The High-Impact Culprits</h3>
                        <p class="text-slate-600">
                            Here are some of the most surprising global averages for everyday items we purchase without a second thought.
                        </p>
                    </div>

                    <!-- Footprint Grid -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Chocolate -->
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 flex flex-col justify-between hover:shadow-md transition-all">
                            <div class="space-y-3">
                                <div class="text-red-600 text-3xl"><i class="fa-solid fa-cubes-stacked"></i></div>
                                <h4 class="font-display font-bold text-lg text-slate-900">Chocolate (1 kg)</h4>
                                <p class="text-slate-500 text-sm">Cacao crops require heavy, multi-year tropical irrigation pipelines before processing.</p>
                            </div>
                            <div class="mt-6 border-t border-slate-50 pt-4">
                                <span class="text-2xl font-black text-slate-900">17,200 L</span>
                                <span class="block text-xs text-slate-400 uppercase font-bold mt-1">Virtual Cost</span>
                            </div>
                        </div>

                        <!-- Beef -->
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 flex flex-col justify-between hover:shadow-md transition-all">
                            <div class="space-y-3">
                                <div class="text-red-600 text-3xl"><i class="fa-solid fa-cow"></i></div>
                                <h4 class="font-display font-bold text-lg text-slate-900">Beef (1 kg)</h4>
                                <p class="text-slate-500 text-sm">Cattle must drink fresh water and consume thousands of kilograms of heavily watered crops.</p>
                            </div>
                            <div class="mt-6 border-t border-slate-50 pt-4">
                                <span class="text-2xl font-black text-slate-900">15,400 L</span>
                                <span class="block text-xs text-slate-400 uppercase font-bold mt-1">Virtual Cost</span>
                            </div>
                        </div>

                        <!-- Leather Shoes -->
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 flex flex-col justify-between hover:shadow-md transition-all">
                            <div class="space-y-3">
                                <div class="text-orange-600 text-3xl"><i class="fa-solid fa-shoe-prints"></i></div>
                                <h4 class="font-display font-bold text-lg text-slate-900">Leather Shoes (1 pair)</h4>
                                <p class="text-slate-500 text-sm">Combines the heavy agricultural cattle farming footprint with chemical tanning water processes.</p>
                            </div>
                            <div class="mt-6 border-t border-slate-50 pt-4">
                                <span class="text-2xl font-black text-slate-900">8,000 L</span>
                                <span class="block text-xs text-slate-400 uppercase font-bold mt-1">Virtual Cost</span>
                            </div>
                        </div>

                        <!-- Cotton Jeans -->
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 flex flex-col justify-between hover:shadow-md transition-all">
                            <div class="space-y-3">
                                <div class="text-water-600 text-3xl"><i class="fa-solid fa-socks"></i></div>
                                <h4 class="font-display font-bold text-lg text-slate-900">Cotton Jeans (1 pair)</h4>
                                <p class="text-slate-500 text-sm">Cotton is an exceptionally thirsty crop grown in naturally dry, water-stressed regions.</p>
                            </div>
                            <div class="mt-6 border-t border-slate-50 pt-4">
                                <span class="text-2xl font-black text-slate-900">3,780 L</span>
                                <span class="block text-xs text-slate-400 uppercase font-bold mt-1">Virtual Cost</span>
                            </div>
