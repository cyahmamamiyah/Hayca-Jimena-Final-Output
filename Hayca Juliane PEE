        <!-- SECTION 4: FAQs & ACCORDION & ACTION CHEAT SHEET -->
        <section id="faqs" class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
                    
                    <!-- Left: FAQ accordions -->
                    <div class="lg:col-span-7 space-y-6">
                        <div class="space-y-2">
                            <span class="text-xs font-bold uppercase tracking-wider text-water-600">Knowledge Hub</span>
                            <h2 class="font-display font-bold text-3xl text-slate-900">Frequently Asked Questions</h2>
                        </div>

                        <!-- FAQ 1 -->
                        <div class="border border-slate-100 rounded-2xl hover:border-slate-200 transition-colors">
                            <button onclick="toggleFaq(1)" class="w-full text-left p-6 font-display font-bold text-slate-800 flex items-center justify-between focus:outline-none">
                                <span>Does buying locally grown foods decrease my virtual water use?</span>
                                <i id="faq-icon-1" class="fa-solid fa-chevron-down text-slate-400 rotate-icon"></i>
                            </button>
                            <div id="faq-ans-1" class="faq-answer px-6 text-slate-600 text-sm leading-relaxed">
                                <p>
                                    Yes! Locally sourced crops usually rely on natural, regional rainfall patterns (referred to as **green water**) rather than requiring energy-intensive desert irrigation pipelines (known as blue water) to transport raw water across dry climates.
                                </p>
                            </div>
                        </div>

                        <!-- FAQ 2 -->
                        <div class="border border-slate-100 rounded-2xl hover:border-slate-200 transition-colors">
                            <button onclick="toggleFaq(2)" class="w-full text-left p-6 font-display font-bold text-slate-800 flex items-center justify-between focus:outline-none">
                                <span>Are businesses transparent about virtual water?</span>
                                <i id="faq-icon-2" class="fa-solid fa-chevron-down text-slate-400 rotate-icon"></i>
                            </button>
                            <div id="faq-ans-2" class="faq-answer px-6 text-slate-600 text-sm leading-relaxed">
                                <p>
                                    Rarely. Most consumer goods only list direct components or recipe volume inside packaging, leaving out the vast upstream amounts required for agricultural growth, chemical treatment, and industrial machinery cleaning along the production pipeline.
                                </p>
                            </div>
                        </div>

                        <!-- FAQ 3 -->
                        <div class="border border-slate-100 rounded-2xl hover:border-slate-200 transition-colors">
                            <button onclick="toggleFaq(3)" class="w-full text-left p-6 font-display font-bold text-slate-800 flex items-center justify-between focus:outline-none">
                                <span>Is virtual water always harmful to the environment?</span>
                                <i id="faq-icon-3" class="fa-solid fa-chevron-down text-slate-400 rotate-icon"></i>
                            </button>
                            <div id="faq-ans-3" class="faq-answer px-6 text-slate-600 text-sm leading-relaxed">
                                <p>
