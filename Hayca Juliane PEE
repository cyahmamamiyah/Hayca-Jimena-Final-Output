    <!-- MAIN SECTIONS CONTAINER -->
    <main class="pt-20">

        <!-- SECTION 1: HOME PAGE (Hero Section with stark contrast) -->
        <section id="home" class="min-h-[calc(100vh-80px)] py-16 md:py-24 flex items-center relative overflow-hidden bg-gradient-to-b from-water-50/50 to-transparent">
            <!-- Background Blob -->
            <div class="absolute -top-40 -right-40 w-96 h-96 bg-water-100 rounded-full blur-3xl opacity-60 pointer-events-none"></div>
            
            <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <!-- Text Hook -->
                <div class="lg:col-span-7 space-y-6">
                    <div class="inline-flex items-center space-x-2 px-3 py-1.5 rounded-full bg-water-100 text-water-700 text-sm font-semibold">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>The Invisible Freshwater Crisis</span>
                    </div>
                    <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-slate-900 leading-tight">
                        You drank <span class="text-water-600 underline decoration-wavy decoration-water-100">2 liters</span> of water today.<br>
                        But you actually consumed <span class="text-earth-600">3,000</span>.
                    </h1>
                    <p class="text-slate-600 text-lg sm:text-xl max-w-2xl leading-relaxed">
                        Every day, your direct activities (cooking, washing, drinking) only tell a tiny fraction of the story. Welcome to the hidden world of virtual water—the unseen freshwater embedded within your food, your clothes, and your retail habits.
                    </p>
                    <div class="flex flex-col sm:flex-row items-stretch sm:items-center space-y-4 sm:space-y-0 sm:space-x-4 pt-4">
                        <a href="#calculator" class="inline-flex items-center justify-center px-8 h-14 rounded-2xl bg-water-600 text-white font-semibold hover:bg-water-700 shadow-xl shadow-water-600/20 active:scale-95 transition-all">
                            <i class="fa-solid fa-calculator mr-2"></i>
