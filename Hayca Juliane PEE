        <!-- SECTION 3: INTERACTIVE WATER CALCULATOR -->
        <section id="calculator" class="py-20 bg-slate-50 relative">
            <div class="max-w-7xl mx-auto px-6">
                
                <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
                    <div class="inline-flex items-center space-x-2 px-3 py-1.5 rounded-full bg-water-100 text-water-700 text-sm font-semibold">
                        <i class="fa-solid fa-sliders"></i>
                        <span>Calculate Your Impact</span>
                    </div>
                    <h2 class="font-display font-bold text-3xl sm:text-4xl text-slate-900">Personal Water Footprint Calculator</h2>
                    <p class="text-slate-600 text-lg">
                        Input your estimates to see how your routine direct choices compare side-by-side with your embedded industrial consumer purchases.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
                    <!-- User Inputs Form -->
                    <div class="lg:col-span-7 bg-white border border-slate-100 rounded-3xl p-8 sm:p-10 shadow-lg shadow-slate-100/50 space-y-8">
                        
                        <!-- Input 1: Direct Water slider -->
                        <div class="space-y-4">
                            <div class="flex justify-between items-center">
                                <label class="font-display font-bold text-slate-900 flex items-center space-x-2">
                                    <i class="fa-solid fa-shower text-water-600"></i>
                                    <span>Direct Household Daily Water</span>
                                </label>
                                <span class="px-3 py-1 rounded-lg bg-water-50 text-water-700 font-bold text-sm" id="direct-val">100 Liters</span>
                            </div>
                            <input type="range" id="direct-slider" min="30" max="350" value="100" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-water-600">
                            <p class="text-xs text-slate-400">(A typical 8-minute shower is ~60L, and toilet flushes are ~10L each)</p>
                        </div>

                        <!-- Input 2: Beef Servings -->
                        <div class="space-y-4">
                            <div class="flex justify-between items-center">
                                <label class="font-display font-bold text-slate-900 flex items-center space-x-2">
                                    <i class="fa-solid fa-cow text-slate-500"></i>
                                    <span>Weekly Beef Servings</span>
                                </label>
                                <span class="px-3 py-1 rounded-lg bg-slate-50 text-slate-700 font-bold text-sm" id="beef-val">2 Servings</span>
                            </div>
                            <input type="range" id="beef-slider" min="0" max="10" value="2" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-slate-600">
                            <p class="text-xs text-slate-400">(Each single serving [~150g] of beef embeds roughly 2,300 Liters of water)</p>
                        </div>

                        <!-- Input 3: Coffee Cups -->
                        <div class="space-y-4">
                            <div class="flex justify-between items-center">
                                <label class="font-display font-bold text-slate-900 flex items-center space-x-2">
                                    <i class="fa-solid fa-mug-hot text-amber-800"></i>
                                    <span>Daily Coffee Cups</span>
                                </label>
                                <span class="px-3 py-1 rounded-lg bg-amber-50 text-amber-800 font-bold text-sm" id="coffee-val">2 Cups</span>
                            </div>
                            <input type="range" id="coffee-slider" min="0" max="8" value="2" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-amber-800">
                            <p class="text-xs text-slate-400">(One typical cup of hot filter coffee has ~140 Liters of hidden water)</p>
                        </div>

                        <!-- Input 4: New clothes -->
                        <div class="space-y-4">
                            <div class="flex justify-between items-center">
                                <label class="font-display font-bold text-slate-900 flex items-center space-x-2">
                                    <i class="fa-solid fa-shirt text-teal-600"></i>
                                    <span>Monthly Clothes Purchased</span>
                                </label>
                                <span class="px-3 py-1 rounded-lg bg-teal-50 text-teal-700 font-bold text-sm" id="clothes-val">1 Item</span>
                            </div>
                            <input type="range" id="clothes-slider" min="0" max="8" value="1" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-teal-600">
                            <p class="text-xs text-slate-400">(One cotton garment embeds around 2,500 - 3,500 Liters of water)</p>
                        </div>

                    </div>

                    <!-- Result Panel -->
                    <div class="lg:col-span-5 bg-gradient-to-br from-water-900 to-slate-900 text-white rounded-3xl p-8 sm:p-10 flex flex-col justify-between shadow-xl">
                        <div class="space-y-6">
                            <h3 class="font-display font-bold text-xl text-water-100 border-b border-white/10 pb-4">Estimated Daily Water Use</h3>
                            
                            <!-- Large Metric Output -->
                            <div class="space-y-1">
                                <span class="text-6xl font-black text-white" id="total-val">1,215</span>
                                <span class="text-xl font-medium block text-water-100">Liters / Day</span>
                            </div>

                            <p class="text-slate-300 text-sm leading-relaxed" id="summary-text">
                                Your choices save substantial freshwater compared to average global baselines. Keep adopting smart alternative swaps!
                            </p>
                        </div>

                        <div class="space-y-4 pt-8 border-t border-white/10">
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-400">Direct Household:</span>
                                <span class="font-bold text-white" id="direct-out">100 L</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-400">Virtual (Agriculture/Retail):</span>
                                <span class="font-bold text-white text-teal-300" id="virtual-out">1,115 L</span>
