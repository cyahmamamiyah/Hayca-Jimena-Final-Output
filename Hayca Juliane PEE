    <!-- INTERACTIVE JAVASCRIPT LOGIC -->
    <script>
        // 1. FAQ Accordion Handler
        function toggleFaq(id) {
            const answer = document.getElementById(`faq-ans-${id}`);
            const icon = document.getElementById(`faq-icon-${id}`);
            
            if (answer.classList.contains('active')) {
                answer.classList.remove('active');
                icon.classList.remove('active');
            } else {
                // Close any open answers first
                document.querySelectorAll('.faq-answer').forEach(el => el.classList.remove('active'));
                document.querySelectorAll('.rotate-icon').forEach(el => el.classList.remove('active'));
                
                answer.classList.add('active');
                icon.classList.add('active');
            }
        }

        // 2. Calculator Footprint Logic
        const directSlider = document.getElementById('direct-slider');
        const beefSlider = document.getElementById('beef-slider');
        const coffeeSlider = document.getElementById('coffee-slider');
        const clothesSlider = document.getElementById('clothes-slider');

        const directVal = document.getElementById('direct-val');
        const beefVal = document.getElementById('beef-val');
        const coffeeVal = document.getElementById('coffee-val');
        const clothesVal = document.getElementById('clothes-val');

        const totalVal = document.getElementById('total-val');
        const directOut = document.getElementById('direct-out');
        const virtualOut = document.getElementById('virtual-out');
        const summaryText = document.getElementById('summary-text');

        function updateCalculator() {
            const direct = parseInt(directSlider.value);
            const beefServings = parseInt(beefSlider.value);
            const coffeeCups = parseInt(coffeeSlider.value);
            const clothesItems = parseInt(clothesSlider.value);

            // Update Input Labels
            directVal.textContent = `${direct} Liters`;
            beefVal.textContent = `${beefServings} ${beefServings === 1 ? 'Serving' : 'Servings'}`;
            coffeeVal.textContent = `${coffeeCups} ${coffeeCups === 1 ? 'Cup' : 'Cups'}`;
            clothesVal.textContent = `${clothesItems} ${clothesItems === 1 ? 'Item' : 'Items'}`;

            // Calculate Upstream Volumes
            // Beef serving (150g) ~2,300L -> converted to daily impact (/7 days)
            const beefDailyVirtual = Math.round((beefServings * 2300) / 7);
            // 1 cup of coffee ~140L virtual footprint
            const coffeeDailyVirtual = coffeeCups * 140;
            // 1 clothing item average ~3,000L footprint -> converted to daily impact (/30 days)
            const clothesDailyVirtual = Math.round((clothesItems * 3000) / 30);

            const totalVirtual = beefDailyVirtual + coffeeDailyVirtual + clothesDailyVirtual;
            const absoluteTotal = direct + totalVirtual;

            // Render Output Cards
            totalVal.textContent = absoluteTotal.toLocaleString();
            directOut.textContent = `${direct} L`;
            virtualOut.textContent = `${totalVirtual.toLocaleString()} L`;

            // Dynamic Contextual Feedback text based on thresholds
            if (absoluteTotal > 2500) {
                summaryText.textContent = "Your estimated daily lifestyle footprint is currently higher than sustainable baselines. Discover the Empowerment Guide below for quick ways to optimize your layout.";
            } else {
                summaryText.textContent = "Excellent work! Your calculated consumer choices save substantial freshwater compared to average global baselines. Keep adopting smart alternative swaps!";
            }
        }

        // Attach event listeners for real-time calculation tracking
        [directSlider, beefSlider, coffeeSlider, clothesSlider].forEach(slider => {
            slider.addEventListener('input', updateCalculator);
        });

        // Initialize calculator with baseline default conditions
        updateCalculator();
    </script>
